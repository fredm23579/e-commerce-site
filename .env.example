# ─── Server ───────────────────────────────────────────────────────────────────

# MongoDB connection URI.
# Local default is used if this variable is not set.
MONGODB_URI=mongodb://127.0.0.1:27017/mern-shopping

# Secret used to sign and verify JWT tokens.
# Must be a long, random string — never commit the real value!
JWT_SECRET=replace_with_a_long_random_secret

# Stripe secret key (server-side only — never expose in the browser).
# Get yours from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Port the Express server listens on (defaults to 3001 when omitted).
PORT=3001

# ─── Client ───────────────────────────────────────────────────────────────────
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Stripe publishable key (safe to expose in the browser).
VITE_STRIPE_PUBLIC_KEY=pk_test_...
